{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../../../kat_rec_web/frontend/out",
    "distDir": "../../../kat_rec_web/frontend/out",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Kat Rec Control Center",
    "version": "0.9.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": true,
        "sidecar": false,
        "open": false
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true
      },
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "http://127.0.0.1:8000",
          "http://127.0.0.1:8001",
          "http://127.0.0.1:8002",
          "http://127.0.0.1:8003",
          "http://127.0.0.1:8004",
          "http://127.0.0.1:8005",
          "http://127.0.0.1:8006",
          "http://127.0.0.1:8007",
          "http://127.0.0.1:8008",
          "http://127.0.0.1:8009",
          "http://127.0.0.1:8010",
          "ws://127.0.0.1:8000",
          "ws://127.0.0.1:8001",
          "ws://127.0.0.1:8002",
          "ws://127.0.0.1:8003",
          "ws://127.0.0.1:8004",
          "ws://127.0.0.1:8005",
          "ws://127.0.0.1:8006",
          "ws://127.0.0.1:8007",
          "ws://127.0.0.1:8008",
          "ws://127.0.0.1:8009",
          "ws://127.0.0.1:8010"
        ]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.katrec.control",
      "icon": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Kat Rec Control Center",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}

