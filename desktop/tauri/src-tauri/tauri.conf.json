{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../../kat_rec_web/frontend/out",
    "distDir": "../../kat_rec_web/frontend/out",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Kat Rec Control Center",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": true,
        "sidecar": false,
        "open": false
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true
      },
      "http": {
        "all": false,
        "request": true,
        "scope": ["http://127.0.0.1:*", "ws://127.0.0.1:*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.katrec.control",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Kat Rec Control Center",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}

