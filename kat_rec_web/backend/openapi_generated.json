  "components": {
    "schemas": {
      "ChannelConfig": {
        "properties": {
          "youtube_channel_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Youtube Channel Id"
          },
          "playlist_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Playlist Id"
          },
          "upload_privacy": {
            "type": "string",
            "title": "Upload Privacy",
            "default": "unlisted"
          },
          "schedule_interval_days": {
            "type": "integer",
            "title": "Schedule Interval Days",
            "default": 2
          },
          "library_paths": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Library Paths",
            "default": {
              "songs": "/library/songs",
              "images": "/library/images"
            }
          }
        },
        "type": "object",
        "title": "ChannelConfig",
        "description": "Pydantic model for channel configuration",
        "example": {
          "library_paths": {
            "images": "/library/images",
            "songs": "/library/songs"
          },
          "playlist_id": "PLxxxxxxxxxxxxx",
          "schedule_interval_days": 2,
          "upload_privacy": "unlisted",
          "youtube_channel_id": "UCxxxxxxxxxxxxx"
        }
      },
      "ChannelResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "config": {
            "$ref": "#/components/schemas/ChannelConfig"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "config",
          "is_active",
          "created_at",
          "updated_at"
        ],
        "title": "ChannelResponse",
        "description": "API response model for Channel"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "TaskControlRequest": {
        "properties": {
          "channel_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Channel Id"
          },
          "action": {
            "type": "string",
            "title": "Action"
          },
          "channels": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Channels"
          }
        },
        "type": "object",
        "required": [
          "action"
        ],
        "title": "TaskControlRequest"
      },
      "TaskControlResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "channel_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Channel Id"
          },
          "channels": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Channels"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "status",
          "message",
          "timestamp"
        ],
        "title": "TaskControlResponse"
      },
      "UploadTaskRequest": {
        "properties": {
          "episode_id": {
            "type": "string",
            "title": "Episode Id"
          },
          "video_file": {
            "type": "string",
            "title": "Video File"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "privacy": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Privacy",
            "default": "unlisted"
          }
        },
        "type": "object",
        "required": [
