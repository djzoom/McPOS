    "/api/task/control": {
      "post": {
        "tags": [
          "control"
        ],
        "summary": "Control Task",
        "description": "Control task for a channel or batch of channels\n\nActions:\n- start: Start a new task\n- pause: Pause current task\n- retry: Retry failed task\n- stop: Stop current task\n- retry_failed: Retry failed tasks for multiple channels (requires 'channels' field)\n\nExamples:\n- Single channel: {\"channel_id\": \"CH-001\", \"action\": \"start\"}\n- Batch retry: {\"action\": \"retry_failed\", \"channels\": [\"CH-006\", \"CH-009\"]}",
        "operationId": "control_task_api_task_control_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskControlRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskControlResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
